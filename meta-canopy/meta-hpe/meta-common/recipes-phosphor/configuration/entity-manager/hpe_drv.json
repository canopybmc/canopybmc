[
    {
        "Exposes": [
            {
                "Address": "0x6a",
                "Bus": "$BUS",
                "Name": "NVME $BUS - 100 + 1 Temp",
                "PollRate": 10,
                "PowerState": "On",
                "Thresholds": [
                    {
                        "Direction": "greater than",
                        "Label": "temp1",
                        "Name": "upper critical",
                        "Severity": 1,
                        "Value": 90
                    },
                    {
                        "Direction": "less than",
                        "Label": "temp1",
                        "Name": "lower critical",
                        "Severity": 1,
                        "Value": 10
                    }
                ],
                "Type": "NVME1000"
            }
        ],
        "Name": "NVME $BUS - 100 + 1",
        "Probe": [
            "xyz.openbmc_project.FruDevice({'ADDRESS': 83})",
            "AND",
            "FOUND('chassis')"
        ],
        "Type": "NVMe",
        "xyz.openbmc_project.Inventory.Decorator.Asset": {
            "Manufacturer": "$PRODUCT_MANUFACTURER",
            "Model": "$PRODUCT_PRODUCT_NAME",
            "PartNumber": "$PRODUCT_PART_NUMBER",
            "SerialNumber": "$PRODUCT_SERIAL_NUMBER"
        },
        "xyz.openbmc_project.Inventory.Item.Chassis": {}
    }
