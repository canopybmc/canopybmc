[Unit]
Description=OpenBMC ipKVM daemon
ConditionPathIsMountPoint=/sys/kernel/config

[Service]
Restart=always
ExecStartPre=/usr/bin/create_usbhid.sh disconnect
ExecStartPre=/usr/bin/create_usbhid.sh connect
ExecStart=/usr/bin/obmc-ikvm -v /dev/video0 -k /dev/hidg0 -p /dev/hidg1 -u 80401000.usb
ExecStopPost=/usr/bin/create_usbhid.sh disconnect

[Install]
WantedBy=multi-user.target
