	i2c86 = "/ahb@80000000/i2cmux@4/i2c4@3";
	i2c87 = "/ahb@80000000/i2cmux@4/i2c4@4";
	/* PCA9546 drive-bay legs 0/1 (drive FRU 0x53 / NVMe temp 0x6a) */
	i2c100 = "/ahb@80000000/i2cmux@3/i2c3@1/switch@72/i2c@0";
	i2c101 = "/ahb@80000000/i2cmux@3/i2c3@1/switch@72/i2c@1";
	i2c102 = "/ahb@80000000/i2cmux@3/i2c3@2/switch@72/i2c@0";
