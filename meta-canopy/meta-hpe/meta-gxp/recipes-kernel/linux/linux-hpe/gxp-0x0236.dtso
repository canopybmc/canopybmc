/dts-v1/;
/plugin/;
&{/} {
	model = "HPE ProLiant DL380 Gen11";
	compatible = "hpe,gxp-dl380gen11", "hpe,gxp";
};
&{/ahb@80000000} {
	kcs_conf: kcs_conf@80fc0430 {
		compatible = "hpe,gxp-kcs-bmc-cfg", "simple-mfd", "syscon";
		reg = <0x80fc0430 0x100>;
	};

	kcs_reg: kcs_reg@80fd0400 {
		compatible = "hpe,gxp-kcs-bmc";
		reg = <0x80fd0400 0x8>;
		interrupts = <6>;
		interrupt-parent = <&vic1>;
		kcs-chan = <1>;
		status = "okay";
		kcs-bmc-cfg = <&kcs_conf>;
	};

	i2cmux3: i2cmux@3 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c3>;
		mux-controls = <&i2c_mux_ctrl 3>;
		#address-cells = <1>;
		#size-cells = <0>;
		/* 5 7 9 b */
		i2c3_1: i2c3@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom1: piceeprom@57 {
				compatible = "atmel,24c02";
				label = "piceeprom1";
				reg = <0x57>;
				vcc-supply = <&i2c_passthrough>;
			};
			ubm1: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&i2c_passthrough>;
				reg = <0x40>;
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				vdd-supply = <&i2c_passthrough>;
				i2c-mux-idle-disconnect;
				drv1: i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
				};
				drv2: i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
				};
				i2c@2 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <2>;
				};
				i2c@3 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <3>;
				};
			};
		};
		i2c3_2: i2c3@2 {
			reg = <2>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom2: piceeprom@57 {
				compatible = "atmel,24c02";
				label = "piceeprom2";
				reg = <0x57>;
				vcc-supply = <&i2c_passthrough>;
			};
			ubm2: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&i2c_passthrough>;
				reg = <0x40>;
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				vdd-supply = <&i2c_passthrough>;
				i2c-mux-idle-disconnect;
				drv3: i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
				};
				drv4: i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
				};
				i2c@2 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <2>;
				};
				i2c@3 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <3>;
				};
			};
		};
