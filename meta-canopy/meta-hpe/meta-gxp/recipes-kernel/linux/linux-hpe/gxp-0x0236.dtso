					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
				};
				i2c@2 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <2>;
				};
				i2c@3 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <3>;
				};
			};
		};
	};
	i2cmux4: i2cmux@4 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c4>;
		mux-controls = <&i2c_mux_ctrl 4>;
		#address-cells = <1>;
		#size-cells = <0>;
		i2c4_3: i2c4@3 {
			reg = <3>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom17: piceeprom@57 {
				compatible = "atmel,24c02";
				label = "piceeprom17";
				reg = <0x57>;
				vcc-supply = <&i2c_passthrough>;
			};
			ubm17: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&i2c_passthrough>;
				reg = <0x40>;
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				vdd-supply = <&i2c_passthrough>;
				i2c-mux-idle-disconnect;
				drv33: i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
				};
				drv34: i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
				};
				i2c@2 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <2>;
				};
				i2c@3 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <3>;
				};
			};
		};
		i2c4_4: i2c4@4 {
			reg = <4>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom18: piceeprom@57 {
				compatible = "atmel,24c02";
				label = "piceeprom18";
				reg = <0x57>;
				vcc-supply = <&i2c_passthrough>;
			};
			ubm18: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&i2c_passthrough>;
				reg = <0x40>;
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				vdd-supply = <&i2c_passthrough>;
				i2c-mux-idle-disconnect;
				drv35: i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
				};
				drv36: i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
				};
				i2c@2 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <2>;
				};
				i2c@3 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <3>;
				};
			};
		};
	};
	i2cmux6: i2cmux@6 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c6>;
		mux-controls = <&i2c_mux_ctrl 6>;
		#address-cells = <1>;
		#size-cells = <0>;
		i2c6_11: i2c6@11 {
			reg = <11>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom19: piceeprom@19 {
				compatible = "atmel,24c02";
				label = "piceeprom19";
				reg = <0x57>;
			};
			ubm19: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&host_power>;
				reg = <0x40>;
				#gpio-cells = <2>;
				gpio-line-names = "19_DRV37_PRESENCE", "19_DRV37_UUID", "19_DRV37_ACT",
				"19_DRV38_PRESENCE", "19_DRV38_UUID", "19_DRV38_ACT";
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					drveeprom37@53 {
						compatible = "atmel,24c02";
						label = "drv37";
						reg = <0x53>;
					};
					thermsensor37@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv37>;
						reg = < 0x1b>;
					};
				};
				i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
					drveeprom38@53 {
						compatible = "atmel,24c02";
						label = "drv38";
						reg = <0x53>;
					};
					thermsensor38@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv38>;
						reg = < 0x1b>;
					};
				};
			};
		};
		i2c6_12: i2c6@12 {
			reg = <12>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom20: piceeprom@20 {
				compatible = "atmel,24c02";
				label = "piceeprom20";
				reg = <0x57>;
			};
			ubm20: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&host_power>;
				reg = <0x40>;
				#gpio-cells = <2>;
				gpio-line-names = "20_DRV39_PRESENCE", "20_DRV39_UUID", "20_DRV39_ACT",
				"20_DRV40_PRESENCE", "20_DRV40_UUID", "20_DRV40_ACT";
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					drveeprom39@53 {
						compatible = "atmel,24c02";
						label = "drv39";
						reg = <0x53>;
					};
					thermsensor39@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv39>;
						reg = < 0x1b>;
					};
				};
				i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
					drveeprom40@53 {
						compatible = "atmel,24c02";
						label = "drv40";
						reg = <0x53>;
					};
					thermsensor40@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv40>;
						reg = < 0x1b>;
					};
				};
			};
		};
		i2c6_13: i2c6@13 {
			reg = <13>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom21: piceeprom@21 {
				compatible = "atmel,24c02";
				label = "piceeprom21";
				reg = <0x57>;
			};
			ubm21: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&host_power>;
				reg = <0x40>;
				#gpio-cells = <2>;
				gpio-line-names = "21_DRV41_PRESENCE", "21_DRV41_UUID", "21_DRV41_ACT",
				"21_DRV42_PRESENCE", "21_DRV42_UUID", "21_DRV42_ACT";
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					drveeprom41@53 {
						compatible = "atmel,24c02";
						label = "drv41";
						reg = <0x53>;
					};
					thermsensor41@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv41>;
						reg = < 0x1b>;
					};
				};
				i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
					drveeprom42@53 {
						compatible = "atmel,24c02";
						label = "drv42";
						reg = <0x53>;
					};
					thermsensor42@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv42>;
						reg = < 0x1b>;
					};
				};
			};
		};
		i2c6_14: i2c6@14 {
			reg = <14>;
			#address-cells = <1>;
			#size-cells = <0>;
			piceeprom22: piceeprom@22 {
				compatible = "atmel,24c02";
				label = "piceeprom22";
				reg = <0x57>;
			};
			ubm22: ubm@40 {
				compatible = "ubm4";
				vcc-supply = <&host_power>;
				reg = <0x40>;
				#gpio-cells = <2>;
				gpio-line-names = "22_DRV43_PRESENCE", "22_DRV43_UUID", "22_DRV43_ACT",
				"22_DRV44_PRESENCE", "22_DRV44_UUID", "22_DRV44_ACT";
			};
			switch@72 {
				compatible = "nxp,pca9546";
				#address-cells = <1>;
				#size-cells = <0>;
				reg = <0x72>;
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					drveeprom43@53 {
						compatible = "atmel,24c02";
						label = "drv43";
						reg = <0x53>;
					};
					thermsensor43@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv43>;
						reg = < 0x1b>;
					};
				};
				i2c@1 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <1>;
					drveeprom44@53 {
						compatible = "atmel,24c02";
						label = "drv44";
						reg = <0x53>;
					};
					thermsensor44@1b {
						compatible = "ubm-drv";
						uid-led = <&leddrv44>;
						reg = < 0x1b>;
					};
				};
			};
		};
	};
	/* add PSU mux */
	i2cmux@7 {
		compatible = "i2c-mux";
		i2c-parent = <&i2c7>;
		mux-controls = <&i2c_mux_ctrl 7>;
		#address-cells = <1>;
		#size-cells = <0>;
		i2c7@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			psu1: psu@58 {
				compatible = "hpe,gxp-psu";
				reg = <0x58>;
			};
		};
		i2c7@2 {
			reg = <2>;
			#address-cells = <1>;
			#size-cells = <0>;
			psu2: psu@59 {
				compatible = "hpe,gxp-psu";
				reg = <0x59>;
			};
		};
	};
	syspower: syspower {
		compatible = "hpe,gxp-power";
		psu_phandle = <&psu1>, <&psu2>;
	};
	leddrv37: leddrv37 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm19 1 0>;
			default-state = "off";
		};
	};
	leddrv38: leddrv38 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm19 4 0>;
			default-state = "off";
		};
	};
	leddrv39: leddrv39 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm20 1 0>;
			default-state = "off";
		};
	};
	leddrv40: leddrv40 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm20 4 0>;
			default-state = "off";
		};
	};
	leddrv41: leddrv41 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm21 1 0>;
			default-state = "off";
		};
	};
	leddrv42: leddrv42 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm21 4 0>;
			default-state = "off";
		};
	};
	leddrv43: leddrv43 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm22 1 0>;
			default-state = "off";
		};
	};
	leddrv44: leddrv44 {
		compatible = "gpio-leds";
		uid {
			gpios = <&ubm22 4 0>;
			default-state = "off";
		};
	};
};

&{/aliases} {
	/* Base i2c controllers - fix bus numbers to match node index */
	i2c0 = "/ahb@80000000/i2c@c0002000";
	i2c1 = "/ahb@80000000/i2c@c0002100";
	i2c2 = "/ahb@80000000/i2c@c0002200";
	i2c3 = "/ahb@80000000/i2c@c0002300";
	i2c4 = "/ahb@80000000/i2c@c0002400";
	i2c5 = "/ahb@80000000/i2c@c0002500";
	i2c6 = "/ahb@80000000/i2c@c0002600";
	i2c7 = "/ahb@80000000/i2c@c0002700";
	i2c8 = "/ahb@80000000/i2c@c0002800";
	i2c9 = "/ahb@80000000/i2c@c0002900";
	/* PSU channels (i2cmux@7) */
	i2c30 = "/ahb@80000000/i2cmux@7/i2c7@1";
	i2c31 = "/ahb@80000000/i2cmux@7/i2c7@2";
	/* UBM backplane channel buses (FRU EEPROM 0x57) */
	i2c70 = "/ahb@80000000/i2cmux@3/i2c3@1";
	i2c71 = "/ahb@80000000/i2cmux@3/i2c3@2";
	i2c72 = "/ahb@80000000/i2cmux@3/i2c3@3";
