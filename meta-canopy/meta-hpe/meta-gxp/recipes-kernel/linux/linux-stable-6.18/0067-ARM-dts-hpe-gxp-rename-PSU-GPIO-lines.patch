From ed2e3ab2b1652dbe6a9c8e4c87ba84db0c08be01 Mon Sep 17 00:00:00 2001
From: Christian Walter <christian.walter@9elements.com>
Date: Sun, 15 Feb 2026 23:54:17 +0100
Subject: [PATCH] ARM: dts: hpe-gxp: rename PSU GPIO lines to match
 entity-manager

Rename the xreg PSU GPIO line names from the lowercase-hyphenated
convention (psu1-installed, psu1-ac-ok, psu1-dc-ok) to the uppercase
convention used by HPE entity-manager configs (INST_PSU1, PSU1_AC,
PSU1_DC). This allows psusensor to resolve the PresenceGpio names
from the entity-manager PSU configuration template.
---
 arch/arm/boot/dts/hpe/hpe-gxp.dts | 24 ++++++++++++------------
 1 file changed, 12 insertions(+), 12 deletions(-)

diff --git a/arch/arm/boot/dts/hpe/hpe-gxp.dts b/arch/arm/boot/dts/hpe/hpe-gxp.dts
index 8aa307e13b79..9973947d978e 100644
--- a/arch/arm/boot/dts/hpe/hpe-gxp.dts
+++ b/arch/arm/boot/dts/hpe/hpe-gxp.dts
@@ -157,24 +157,24 @@ xreg: xreg@d1000000 {
 				"", "", "", "", "", "", "", "",
 				"", "", "", "", "", "", "", "", "",
 				/* 90-97: PSU installed */
-				"psu1-installed", "psu2-installed",
-				"psu3-installed", "psu4-installed",
-				"psu5-installed", "psu6-installed",
-				"psu7-installed", "psu8-installed",
+				"INST_PSU1", "INST_PSU2",
+				"INST_PSU3", "INST_PSU4",
+				"INST_PSU5", "INST_PSU6",
+				"INST_PSU7", "INST_PSU8",
 				/* 98-99: Reserved */
 				"", "",
 				/* 100-107: PSU AC OK */
-				"psu1-ac-ok", "psu2-ac-ok",
-				"psu3-ac-ok", "psu4-ac-ok",
-				"psu5-ac-ok", "psu6-ac-ok",
-				"psu7-ac-ok", "psu8-ac-ok",
+				"PSU1_AC", "PSU2_AC",
+				"PSU3_AC", "PSU4_AC",
+				"PSU5_AC", "PSU6_AC",
+				"PSU7_AC", "PSU8_AC",
 				/* 108-109: Reserved */
 				"", "",
 				/* 110-117: PSU DC OK */
-				"psu1-dc-ok", "psu2-dc-ok",
-				"psu3-dc-ok", "psu4-dc-ok",
-				"psu5-dc-ok", "psu6-dc-ok",
-				"psu7-dc-ok", "psu8-dc-ok";
+				"PSU1_DC", "PSU2_DC",
+				"PSU3_DC", "PSU4_DC",
+				"PSU5_DC", "PSU6_DC",
+				"PSU7_DC", "PSU8_DC";
 		};
 
 		fn2: fn2@80200000 {
-- 
2.48.1

