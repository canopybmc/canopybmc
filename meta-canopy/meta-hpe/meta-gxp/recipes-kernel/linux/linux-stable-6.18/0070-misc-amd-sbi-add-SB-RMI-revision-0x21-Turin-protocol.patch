 	 * For RMI Rev 0x20, new h/w status bit is introduced. which is used
diff --git a/drivers/misc/amd-sbi/rmi-hwmon.c b/drivers/misc/amd-sbi/rmi-hwmon.c
index f4f0156..63f1c1a 100644
--- a/drivers/misc/amd-sbi/rmi-hwmon.c
+++ b/drivers/misc/amd-sbi/rmi-hwmon.c
@@ -35,7 +35,16 @@ static int sbrmi_read(struct device *dev, enum hwmon_sensor_types type,
 		ret = rmi_mailbox_xfer(data, &msg);
 		break;
 	case hwmon_power_cap_max:
-		msg.mb_in_out = data->pwr_limit_max;
+		/* Populate cache on first read if probe couldn't */
+		if (READ_ONCE(data->pwr_limit_max) == 0) {
+			msg.cmd = SBRMI_READ_PKG_PWR_LIMIT;
+			ret = rmi_mailbox_xfer(data, &msg);
+			if (ret < 0)
+				return ret;
+
+			WRITE_ONCE(data->pwr_limit_max, msg.mb_in_out);
+		}
+		msg.mb_in_out = READ_ONCE(data->pwr_limit_max);
 		ret = 0;
 		break;
 	default:
diff --git a/drivers/misc/amd-sbi/rmi-i2c.c b/drivers/misc/amd-sbi/rmi-i2c.c
index 205ef7b..011d70e 100644
--- a/drivers/misc/amd-sbi/rmi-i2c.c
+++ b/drivers/misc/amd-sbi/rmi-i2c.c
@@ -16,6 +16,82 @@
 #include <linux/regmap.h>
 #include "rmi-core.h"
 
+/* Try 2-byte address size before falling back to 1-byte */
+#define MAX_RETRY 5
+
+/*
+ * There are processors with RMI address size as 2 bytes and others with 1 byte,
+ * with no clear detection mechanism in place.
+ * Execute 2-byte access first, and then fall back to 1-byte.
+ * Sending 2-byte first is safer: sending 1-byte address size on
+ * Turin (2-byte) can cause an unrecoverable error requiring a system reboot.
+ */
+static int configure_regmap(struct i2c_client *client, struct sbrmi_data *data)
+{
+	struct regmap_config sbrmi_i2c_regmap_config = {
+		.reg_bits = 8,
+		.val_bits = 8,
+	};
+	struct regmap_config sbrmi_i2c_regmap_config_2_bytes = {
+		.reg_bits = 16,
+		.val_bits = 8,
+		.reg_format_endian = REGMAP_ENDIAN_LITTLE,
+	};
+	u32 i;
+	int ret, rev;
+
+	if (!client || !data)
+		return -ENODEV;
+
+	/* Try 2-byte register address first (Turin/v21) */
+	data->regmap =
+		devm_regmap_init_i2c(client, &sbrmi_i2c_regmap_config_2_bytes);
+	if (IS_ERR(data->regmap))
+		return PTR_ERR(data->regmap);
+
+	for (i = 0; i < MAX_RETRY; i++) {
+		ret = regmap_read(data->regmap, SBRMI_REV, &rev);
+		if (ret < 0) {
+			usleep_range(10000, 20000);
+			continue;
+		} else {
+			break;
+		}
+	}
+
+	/*
+	 * Fall back to 1-byte register address size.
+	 * Check for revision 0x21 to not break backward compatibility
+	 * for some Family:0x19 processors.
+	 */
+	if (ret || rev != 0x21) {
+		data->regmap =
+			devm_regmap_init_i2c(client, &sbrmi_i2c_regmap_config);
+		if (IS_ERR(data->regmap))
+			return PTR_ERR(data->regmap);
+
+		ret = regmap_read(data->regmap, SBRMI_REV, &rev);
+		if (ret < 0)
+			return ret;
+	}
+	data->rev = rev;
+
+	/*
+	 * For some Turin platforms, the first 1-byte transaction can succeed.
+	 * Verify the revision: if 0x21, switch to 2-byte address size.
+	 */
+	if (data->rev == 0x21)
+		data->regmap = devm_regmap_init_i2c(
+			client, &sbrmi_i2c_regmap_config_2_bytes);
+	else
+		data->regmap =
+			devm_regmap_init_i2c(client, &sbrmi_i2c_regmap_config);
+	if (IS_ERR(data->regmap))
+		return PTR_ERR(data->regmap);
+
+	return ret;
+}
+
 static int sbrmi_enable_alert(struct sbrmi_data *data)
 {
 	int ctrl, ret;
@@ -43,8 +119,14 @@ static int sbrmi_get_max_pwr_limit(struct sbrmi_data *data)
 
 	msg.cmd = SBRMI_READ_PKG_MAX_PWR_LIMIT;
 	ret = rmi_mailbox_xfer(data, &msg);
-	if (ret < 0)
+	if (ret < 0) {
+		if (msg.fw_ret_code == 0x01) {
+			/* Handle case where FW is not ready */
+			return -EPROBE_DEFER;
+		}
 		return ret;
+	}
+
 	data->pwr_limit_max = msg.mb_in_out;
 
 	return ret;
@@ -54,10 +136,6 @@ static int sbrmi_i2c_probe(struct i2c_client *client)
 {
 	struct device *dev = &client->dev;
 	struct sbrmi_data *data;
-	struct regmap_config sbrmi_i2c_regmap_config = {
-		.reg_bits = 8,
-		.val_bits = 8,
-	};
 	int ret;
 
 	data = devm_kzalloc(dev, sizeof(struct sbrmi_data), GFP_KERNEL);
@@ -79,9 +157,9 @@ static int sbrmi_i2c_probe(struct i2c_client *client)
 
 	mutex_init(&data->lock);
 
-	data->regmap = devm_regmap_init_i2c(client, &sbrmi_i2c_regmap_config);
-	if (IS_ERR(data->regmap))
-		return PTR_ERR(data->regmap);
+	ret = configure_regmap(client, data);
+	if (ret)
+		return ret;
 
 	/* Enable alert for SB-RMI sequence */
 	ret = sbrmi_enable_alert(data);
@@ -90,8 +168,12 @@ static int sbrmi_i2c_probe(struct i2c_client *client)
 
 	/* Cache maximum power limit */
 	ret = sbrmi_get_max_pwr_limit(data);
-	if (ret < 0)
-		return ret;
+	if (ret < 0) {
+		/*
+		 * Ignore failure on probe — FW might not be ready.
+		 * The hwmon read path will retry on first access.
+		 */
+	}
 
 	data->dev_static_addr = client->addr;
 	dev_set_drvdata(dev, data);
