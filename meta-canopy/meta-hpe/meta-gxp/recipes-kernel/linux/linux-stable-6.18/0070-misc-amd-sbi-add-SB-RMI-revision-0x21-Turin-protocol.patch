 				    msg->cpu_in_out & CPUID_MCA_FUNC_MASK,
 				    msg->cpu_in_out >> CPUID_EXT_FUNC_INDEX);
 
-	ret = regmap_bulk_write(data->regmap, CPUID_MCA_CMD,
-				&input, CPUID_WR_REG_LEN);
-	if (ret < 0)
+	return regmap_bulk_write(data->regmap, CPUID_MCA_CMD, &input,
+				 CPUID_WR_REG_LEN);
+}
+
+/* CPUID v21 data input helper - uses u16 thread, no THREAD128CS */
+static int cpuid_datain_v21(struct sbrmi_data *data, struct apml_cpuid_msg *msg)
+{
+	struct cpu_msr_indata_v21 input = {0};
+	u16 thread;
+
+	thread = msg->cpu_in_out >> CPUID_MCA_THRD_INDEX;
+
+	input.rd_len = CPUID_RD_DATA_LEN;
+	input.wr_len = CPUID_WR_DATA_LEN_v21;
+	input.proto_cmd = RD_CPUID_CMD;
+	input.thread = thread << 1;
+	input.value = msg->cpu_in_out & CPUID_MCA_FUNC_MASK;
+	input.ext = msg->cpu_in_out >> CPUID_EXT_FUNC_INDEX;
+
+	return regmap_bulk_write(data->regmap, CPUID_MCA_CMD, &input,
+				 CPUID_WR_REG_LEN_v21);
+}
+
+/* Read CPUID function protocol */
+static int rmi_cpuid_read(struct sbrmi_data *data,
+			  struct apml_cpuid_msg *msg)
+{
+	struct cpu_msr_outdata output = {0};
+	int ret, hw_status;
+
+	mutex_lock(&data->lock);
+
+	if (!data->regmap) {
+		ret = -ENODEV;
 		goto exit_unlock;
+	}
+
+	/* cache the rev value to identify if protocol is supported or not */
+	if (!data->rev) {
+		ret = sbrmi_get_rev(data);
+		if (ret < 0)
+			goto exit_unlock;
+	}
+
+	switch (data->rev) {
+	/* CPUID protocol for REV 0x10 is not supported */
+	case 0x10:
+		ret = -EOPNOTSUPP;
+		goto exit_unlock;
+	case 0x20:
+		ret = cpuid_datain_v20(data, msg);
+		if (ret < 0)
+			goto exit_unlock;
+		break;
+	case 0x21:
+		ret = cpuid_datain_v21(data, msg);
+		if (ret < 0)
+			goto exit_unlock;
+		break;
+	default:
+		ret = -EOPNOTSUPP;
+		goto exit_unlock;
+	}
 
 	/*
 	 * For RMI Rev 0x20, new h/w status bit is introduced. which is used
@@ -188,45 +293,44 @@ exit_unlock:
 
