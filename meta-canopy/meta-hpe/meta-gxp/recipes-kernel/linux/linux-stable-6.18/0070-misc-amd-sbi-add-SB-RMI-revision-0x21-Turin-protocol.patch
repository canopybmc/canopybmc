+}
+
+/* MCA MSR v21 data input helper - uses u16 thread, no THREAD128CS */
+static int msr_datain_v21(struct sbrmi_data *data, struct apml_mcamsr_msg *msg)
+{
+	struct cpu_msr_indata_v21 input = {0};
+	u16 thread;
+
+	thread = msg->mcamsr_in_out >> CPUID_MCA_THRD_INDEX;
+
+	input.rd_len = MSR_RD_DATA_LEN;
+	input.wr_len = MSR_WR_DATA_LEN_v21;
+	input.proto_cmd = RD_MCA_CMD;
+	input.thread = thread << 1;
+	input.value = msg->mcamsr_in_out & CPUID_MCA_FUNC_MASK;
+
+	return regmap_bulk_write(data->regmap, CPUID_MCA_CMD, &input,
+				 MSR_WR_REG_LEN_v21);
+}
+
+/* CPUID v20 data input helper */
+static int cpuid_datain_v20(struct sbrmi_data *data, struct apml_cpuid_msg *msg)
+{
+	struct cpu_msr_indata input = {0};
+	int ret, val = 0;
