From 99481446d60a28e7d5b51840145ff6ed0023bcff Mon Sep 17 00:00:00 2001
From: Pedro Maione <pedro.maione@9elements.com>
Date: Wed, 11 Mar 2026 16:06:09 -0300
Subject: [PATCH] ipmi: kcs_bmc_gxp: port driver to Linux v6.18

Update the HPE GXP KCS BMC driver to comply with current kernel APIs
and coding standards:

- Change .remove callback return type from int to void, as required
  since v6.11
- Replace platform_get_resource() + devm_ioremap_resource() with
  devm_platform_ioremap_resource(); remove now-redundant kcsResource
  field from private struct
- Rename DT property "kcs_chan" to "kcs-chan" to comply with DT naming
  conventions
- Add missing MODULE_LICENSE("GPL v2")
- Use `gxp` instead of `hpe` for function naming.
- Include `dt-binding` documentation

No functional changes intended.

Signed-off-by: Pedro Maione <pedro.maione@9elements.com>
---
 .../bindings/ipmi/hpe,gxp-kcs-bmc.yaml        |  63 +++++
 drivers/char/ipmi/Kconfig                     |  12 +
 drivers/char/ipmi/Makefile                    |   1 +
 drivers/char/ipmi/kcs_bmc_gxp.c               | 230 ++++++++++++++++++
 4 files changed, 306 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/ipmi/hpe,gxp-kcs-bmc.yaml
 create mode 100644 drivers/char/ipmi/kcs_bmc_gxp.c

diff --git a/Documentation/devicetree/bindings/ipmi/hpe,gxp-kcs-bmc.yaml b/Documentation/devicetree/bindings/ipmi/hpe,gxp-kcs-bmc.yaml
new file mode 100644
index 000000000000..892ac21bee98
--- /dev/null
+++ b/Documentation/devicetree/bindings/ipmi/hpe,gxp-kcs-bmc.yaml
@@ -0,0 +1,63 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/ipmi/hpe,gxp-kcs-bmc.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: HPE GXP BMC KCS Interface
+
+maintainers:
+  - John Chung <john.chung@hpe.com>
+  - Jorge Cisneros <jorge.cisneros@hpe.com>
+
+description: |
+  The HPE GXP SoC implements a Keyboard Controller Style (KCS) IPMI
+  interface for host-to-BMC communication over the LPC bus.
+
+properties:
+  compatible:
+    const: hpe,gxp-kcs-bmc
+
+  reg:
+    description: Base address and size of the KCS LPC register block.
+    maxItems: 1
+
+  interrupts:
+    maxItems: 1
+
+  kcs-chan:
+    description: KCS logical channel number. Must be 1.
+    minimum: 1
+    maximum: 1
+
+  kcs-bmc-cfg:
+    $ref: /schemas/types.yaml#/definitions/phandle
+    description:
+      Phandle to a syscon node that provides the regmap used to
+      activate the KCS LPC interface.
+
+required:
+  - compatible
+  - reg
+  - interrupts
+  - kcs-chan
+  - kcs-bmc-cfg
+
+additionalProperties: false
+
+examples:
+  - |
+    kcs_conf: kcs_conf@80fc0430 {
+        compatible = "hpe,gxp-kcs-bmc-cfg", "simple-mfd", "syscon";
+        reg = <0x80fc0430 0x100>;
+    };
+
+    kcs_reg: kcs_reg@80fd0400 {
+        compatible = "hpe,gxp-kcs-bmc";
+        reg = <0x80fd0400 0x8>;
+        interrupts = <6>;
+        interrupt-parent = <&vic1>;
+        kcs-chan = <1>;
+        status = "okay";
+        kcs-bmc-cfg = <&kcs_conf>;
+    };
diff --git a/drivers/char/ipmi/Kconfig b/drivers/char/ipmi/Kconfig
index 92bed266d07c..ee7ffdb383fc 100644
--- a/drivers/char/ipmi/Kconfig
+++ b/drivers/char/ipmi/Kconfig
@@ -113,6 +113,18 @@ endif # IPMI_HANDLER
 config IPMI_KCS_BMC
 	tristate
 
+config HPE_KCS_IPMI_BMC
+	tristate "HPE GXP KCS IPMI BMC driver"
+	depends on ARCH_HPE_GXP || COMPILE_TEST
+	select REGMAP_MMIO
+	select IPMI_KCS_BMC
+	help
+	  Provides a driver for the KCS IPMI BMC interface found on
+	  HPE GXP SoC-based BMC platforms.
+
+	  If you are building for an HPE GXP-based system, say Y or M here.
+	  Otherwise say N.
+
 config ASPEED_KCS_IPMI_BMC
 	depends on ARCH_ASPEED || COMPILE_TEST
 	select IPMI_KCS_BMC
diff --git a/drivers/char/ipmi/Makefile b/drivers/char/ipmi/Makefile
index 4ea450a82242..d5fce4c9b35b 100644
--- a/drivers/char/ipmi/Makefile
+++ b/drivers/char/ipmi/Makefile
@@ -29,3 +29,4 @@ obj-$(CONFIG_ASPEED_KCS_IPMI_BMC) += kcs_bmc_aspeed.o
 obj-$(CONFIG_NPCM7XX_KCS_IPMI_BMC) += kcs_bmc_npcm7xx.o
 obj-$(CONFIG_IPMB_DEVICE_INTERFACE) += ipmb_dev_int.o
 obj-$(CONFIG_SSIF_IPMI_BMC) += ssif_bmc.o
+obj-$(CONFIG_HPE_KCS_IPMI_BMC) += kcs_bmc_gxp.o
diff --git a/drivers/char/ipmi/kcs_bmc_gxp.c b/drivers/char/ipmi/kcs_bmc_gxp.c
new file mode 100644
index 000000000000..a81a73c0e501
--- /dev/null
+++ b/drivers/char/ipmi/kcs_bmc_gxp.c
@@ -0,0 +1,230 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (C) 2019 Hewlett-Packard Development Company, L.P.
+ *
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License version 2 as
+ * published by the Free Software Foundation.
+ */
+
+#include <linux/atomic.h>
+#include <linux/errno.h>
+#include <linux/interrupt.h>
+#include <linux/io.h>
+#include <linux/mfd/syscon.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+#include <linux/poll.h>
+#include <linux/regmap.h>
+#include <linux/sched.h>
+#include <linux/slab.h>
+#include <linux/timer.h>
+
+#include "kcs_bmc_device.h"
+
+#define DEVICE_NAME "gxp-kcs-bmc"
+
+#define KCS_CHANNEL_MAX 1
+
+#define GXP_LPC_IDR 0x04
+#define GXP_LPC_ODR 0x04
+#define GXP_LPC_STR 0x05
+#define GXP_LPC_INT 0x06
+
+#define GXP_KCS_AUTOIRQ 0x04
+#define GXP_KCS_MSKOBFINT 0x01
+
+#define GXP_KCS_LPC_ACTIVATE 0x01
+
+	struct gxp_kcs_bmc {
+	struct kcs_bmc_device kcs_bmc;
+	void __iomem *kcsRegMap;
+	struct regmap *kcsCfgMap;
+};
+
+static inline struct gxp_kcs_bmc *to_gxp_kcs_bmc(struct kcs_bmc_device *kcs_bmc)
+{
+	return container_of(kcs_bmc, struct gxp_kcs_bmc, kcs_bmc);
+}
+
+static u8 gxp_kcs_inb(struct kcs_bmc_device *kcs_bmc, u32 reg)
+{
+	struct gxp_kcs_bmc *priv = to_gxp_kcs_bmc(kcs_bmc);
+	u32 val = 0;
+
+	val = readb(priv->kcsRegMap + reg);
+	return (u8)val;
+}
+
+static void gxp_kcs_outb(struct kcs_bmc_device *kcs_bmc, u32 reg, u8 data)
+{
+	struct gxp_kcs_bmc *priv = to_gxp_kcs_bmc(kcs_bmc);
+
+	writeb(data, priv->kcsRegMap + reg);
+}
+
+static void gxp_kcs_updateb(struct kcs_bmc_device *kcs_bmc, u32 reg, u8 mask,
+				u8 val)
+{
+	dev_dbg(kcs_bmc->dev, "reg %x Mask %x Val %x\n", reg, mask, val);
+
+	struct gxp_kcs_bmc *priv = to_gxp_kcs_bmc(kcs_bmc);
+	u8 tmp;
+
+	tmp = readb(priv->kcsRegMap + reg);
+	tmp &= ~mask;
+	tmp |= val & mask;
+	writeb(tmp, priv->kcsRegMap + reg);
+}
+
+static void gxp_kcs_turn_on_auto_irq(struct kcs_bmc_device *kcs_bmc)
+{
+	struct gxp_kcs_bmc *priv = to_gxp_kcs_bmc(kcs_bmc);
+
+	writeb(GXP_KCS_AUTOIRQ | GXP_KCS_MSKOBFINT,
+		   priv->kcsRegMap + GXP_LPC_INT);
+}
+
+static void gxp_kcs_activate(struct kcs_bmc_device *kcs_bmc)
+{
+	struct gxp_kcs_bmc *priv = to_gxp_kcs_bmc(kcs_bmc);
+
+	regmap_write(priv->kcsCfgMap, 0x00, GXP_KCS_LPC_ACTIVATE);
+}
+
+static void gxp_kcs_irq_mask_update(struct kcs_bmc_device *kcs_bmc, u8 mask,
+					u8 state)
+{
+	struct device *dev = kcs_bmc->dev;
+
+	dev_dbg(dev, "Update mask %x state %x\n", mask, state);
+}
+
+static irqreturn_t gxp_kcs_irq(int irq, void *arg)
+{
+	struct kcs_bmc_device *kcs_bmc = arg;
+
+	if (!kcs_bmc_handle_event(kcs_bmc))
+		return IRQ_HANDLED;
+	return IRQ_NONE;
+}
+
+static int gxp_kcs_config_irq(struct kcs_bmc_device *kcs_bmc,
+				  struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	int irq;
+
+	irq = platform_get_irq(pdev, 0);
+	if (irq < 0) {
+		return irq;
+	}
+
+	return devm_request_irq(dev, irq, gxp_kcs_irq, IRQF_SHARED,
+				dev_name(dev), kcs_bmc);
+}
+
+static const struct kcs_ioreg gxp_kcs_bmc_ioregs[KCS_CHANNEL_MAX] = {
+	{ .idr = GXP_LPC_IDR, .odr = GXP_LPC_ODR, .str = GXP_LPC_STR },
+};
+
+static const struct kcs_bmc_device_ops gxp_kcs_ops = {
+	.irq_mask_update = gxp_kcs_irq_mask_update,
+	.io_inputb = gxp_kcs_inb,
+	.io_outputb = gxp_kcs_outb,
+	.io_updateb = gxp_kcs_updateb,
+};
+
+static int gxp_kcs_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct gxp_kcs_bmc *priv;
+	struct kcs_bmc_device *kcs_bmc;
+	u32 chan;
+	int rc;
+
+	// kcs-chan => kcs channel
+	rc = of_property_read_u32(pdev->dev.of_node, "kcs-chan", &chan);
+	if ((rc != 0) || (chan == 0 || chan > KCS_CHANNEL_MAX)) {
+		dev_err(&pdev->dev, "no valid 'kcs-chan' configured\n");
+		return -ENODEV;
+	}
+
+	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	kcs_bmc = &priv->kcs_bmc;
+	kcs_bmc->dev = &pdev->dev;
+	kcs_bmc->channel = chan;
+	kcs_bmc->ioreg = gxp_kcs_bmc_ioregs[chan - 1];
+	kcs_bmc->ops = &gxp_kcs_ops;
+
+	priv->kcsRegMap = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(priv->kcsRegMap))
+		return PTR_ERR(priv->kcsRegMap);
+
+	priv->kcsCfgMap = syscon_regmap_lookup_by_phandle(pdev->dev.of_node,
+							  "kcs-bmc-cfg");
+	if (IS_ERR(priv->kcsCfgMap)) {
+		dev_err(&pdev->dev, "Couldn't get KCS configuration regmap\n");
+		return -ENODEV;
+	}
+
+	platform_set_drvdata(pdev, priv);
+
+	rc = gxp_kcs_config_irq(kcs_bmc, pdev);
+	if (rc) {
+		dev_err(&pdev->dev, "Fail to register IRQ - %d\n", rc);
+		return rc;
+	}
+
+	/* Turn on auto-IRQ to host and only interrupt IOP when IBF is set. */
+	dev_info(&pdev->dev, "Turn on Auto IRQ\n");
+	gxp_kcs_turn_on_auto_irq(kcs_bmc);
+
+	// Turn on KCS0
+	dev_info(&pdev->dev, "Activate KCS Device\n");
+	gxp_kcs_activate(kcs_bmc);
+
+	dev_info(dev, "channel=%u idr=0x%x odr=0x%x str=0x%x\n", chan,
+		 kcs_bmc->ioreg.idr, kcs_bmc->ioreg.odr, kcs_bmc->ioreg.str);
+
+	rc = kcs_bmc_add_device(&priv->kcs_bmc);
+	if (rc) {
+		dev_err(&pdev->dev, "Unable to register device\n");
+		return rc;
+	}
+
+	return 0;
+}
+
+static void gxp_kcs_remove(struct platform_device *pdev)
+{
+	struct gxp_kcs_bmc *priv = platform_get_drvdata(pdev);
+	struct kcs_bmc_device *kcs_bmc = &priv->kcs_bmc;
+
+	kcs_bmc_remove_device(kcs_bmc);
+}
+
+static const struct of_device_id gxp_kcs_bmc_match[] = {
+	{ .compatible = "hpe,gxp-kcs-bmc" },
+	{}
+};
+MODULE_DEVICE_TABLE(of, gxp_kcs_bmc_match);
+
+static struct platform_driver gxp_kcs_bmc_driver = {
+	.driver = {
+		.name           = DEVICE_NAME,
+		.of_match_table = gxp_kcs_bmc_match,
+	},
+	.probe  = gxp_kcs_probe,
+	.remove = gxp_kcs_remove,
+};
+module_platform_driver(gxp_kcs_bmc_driver);
+
+MODULE_AUTHOR("John Chung <john.chung@hpe.com>");
+MODULE_AUTHOR("Jorge Cisneros <jorge.cisneros@hpe.com>");
+MODULE_DESCRIPTION("HPE device interface to the KCS BMC device");
+MODULE_LICENSE("GPL v2");
-- 
