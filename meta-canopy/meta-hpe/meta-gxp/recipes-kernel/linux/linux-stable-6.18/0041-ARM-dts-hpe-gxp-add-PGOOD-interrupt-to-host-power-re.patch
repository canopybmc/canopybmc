From b5fe80e8a3cd477465ff2bbe3343fd0f1e04cd92 Mon Sep 17 00:00:00 2001
From: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
Date: Fri, 13 Feb 2026 11:25:46 +0100
Subject: [PATCH] ARM: dts: hpe-gxp: add PGOOD interrupt to host power
 regulator

Connect the CPLD host power supply regulator to FN2 IRQ domain
line 1 (PGOOD) so the regulator driver can fire notifier events
on host power transitions. This enables event-based PECI device
lifecycle management.

Signed-off-by: Marcello Sylvester Bauer <marcello.bauer@9elements.com>
---
 arch/arm/boot/dts/hpe/hpe-gxp.dts | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/arch/arm/boot/dts/hpe/hpe-gxp.dts b/arch/arm/boot/dts/hpe/hpe-gxp.dts
index acfeb84f9456..684ab1bcbd70 100644
--- a/arch/arm/boot/dts/hpe/hpe-gxp.dts
+++ b/arch/arm/boot/dts/hpe/hpe-gxp.dts
@@ -4,6 +4,9 @@
  */
 
 /dts-v1/;
+
+#include <dt-bindings/interrupt-controller/irq.h>
+
 / {
 	model = "Hewlett Packard Enterprise GXP BMC";
 	compatible = "hpe,gxp";
@@ -207,6 +210,7 @@ chif: chif {
 			host_power: regulator-host-power {
 				compatible = "hpe,gxp-host-power-supply";
 				regulator-name = "host-power";
+				interrupts = <1 IRQ_TYPE_EDGE_BOTH>;
 			};
 		};
 
