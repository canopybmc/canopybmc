From 8837e4b574c10ed976371a790b856a17d2fd418b Mon Sep 17 00:00:00 2001
From: Pedro Maione <pedro.maione@9elements.com>
Date: Mon, 2 Mar 2026 18:01:17 -0300
Subject: [PATCH] hwmon: sbtsi_temp: add regulator supply and probe deferral
 support

Add optional "sbtsi-supply" regulator support. Probe is deferred if
the supply is present but not yet enabled, or if the I2C bus is not
yet responsive (-ETIMEDOUT, -ENXIO, -ENODEV).

Introduce sbtsi_powered() helper to guard read and write paths when
the supply is present but disabled.

Signed-off-by: Pedro Maione <pedro.maione@9elements.com>
---
 drivers/hwmon/sbtsi_temp.c | 45 ++++++++++++++++++++++++++++++++++++++
 1 file changed, 45 insertions(+)

diff --git a/drivers/hwmon/sbtsi_temp.c b/drivers/hwmon/sbtsi_temp.c
index a6c439e376ff..e77b8cd2045d 100644
--- a/drivers/hwmon/sbtsi_temp.c
+++ b/drivers/hwmon/sbtsi_temp.c
@@ -15,6 +15,7 @@
 #include <linux/mutex.h>
 #include <linux/of.h>
 #include <linux/bitfield.h>
+#include <linux/regulator/consumer.h>
 
 /*
  * SB-TSI registers only support SMBus byte data access. "_INT" registers are
@@ -53,6 +54,7 @@
 struct sbtsi_data {
 	struct i2c_client *client;
 	struct mutex lock;
+	struct regulator *supply;
 	bool ext_range_mode;
 	bool read_order;
 };
@@ -86,6 +88,14 @@ static inline void sbtsi_mc_to_reg(s32 temp, u8 *integer, u8 *decimal)
 	*decimal = (temp & 0x7) << 5;
 }
 
+static bool sbtsi_powered(struct sbtsi_data *data)
+{
+	if (!data->supply)
+		return true;
+
+	return regulator_is_enabled(data->supply) > 0;
+}
+
 static int sbtsi_read(struct device *dev, enum hwmon_sensor_types type,
 		      u32 attr, int channel, long *val)
 {
@@ -94,6 +104,11 @@ static int sbtsi_read(struct device *dev, enum hwmon_sensor_types type,
 
 	switch (attr) {
 	case hwmon_temp_input:
+		if (!sbtsi_powered(data)) {
+			temp_dec = 0;
+			temp_int = 0;
+			return 0;
+		}
 		mutex_lock(&data->lock);
 		if (data->read_order) {
 			temp_dec = i2c_smbus_read_byte_data(data->client, SBTSI_REG_TEMP_DEC);
@@ -140,6 +155,9 @@ static int sbtsi_write(struct device *dev, enum hwmon_sensor_types type,
 	int reg_int, reg_dec, err;
 	u8 temp_int, temp_dec;
 
+	if (!sbtsi_powered(data))
+	  return -EACCES;
+
 	switch (attr) {
 	case hwmon_temp_max:
 		reg_int = SBTSI_REG_TEMP_HIGH_INT;
@@ -219,8 +237,35 @@ static int sbtsi_probe(struct i2c_client *client)
 		return -ENOMEM;
 
 	data->client = client;
+
+	data->supply = devm_regulator_get_optional(dev, "sbtsi");
+	if (IS_ERR(data->supply)) {
+		if (PTR_ERR(data->supply) != -ENODEV)
+			return dev_err_probe(dev, PTR_ERR(data->supply),
+						 "failed to get sbtsi supply\n");
+
+		data->supply = NULL;
+	}
+
+	if (data->supply && !regulator_is_enabled(data->supply)) {
+		dev_info(dev, "sbtsi-supply not enabled, deferring probe\n");
+		return -EPROBE_DEFER;
+	}
+
 	mutex_init(&data->lock);
 
+	/* Check if bus is actually responsive */
+	err = i2c_smbus_read_byte_data(client, SBTSI_REG_CONFIG);
+	if (err < 0) {
+		if (err == -ETIMEDOUT || err == -ENXIO || err == -ENODEV)
+			return dev_err_probe(
+				dev, -EPROBE_DEFER,
+				"I2C bus not ready (err=%d), deferring\n", err);
+
+		return dev_err_probe(dev, err,
+					 "failed to read config register\n");
+	}
+
 	err = i2c_smbus_read_byte_data(data->client, SBTSI_REG_CONFIG);
 	if (err < 0)
 		return err;
-- 
2.53.0

