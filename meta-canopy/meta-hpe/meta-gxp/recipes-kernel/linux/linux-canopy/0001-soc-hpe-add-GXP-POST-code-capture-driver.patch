+
+config SOC_HPE_GXP_DBG
+	tristate "HPE GXP POST code capture support"
+	depends on ARCH_HPE_GXP || COMPILE_TEST
+	select SOC_HPE_GXP
+	help
+	  Say Y here to add support for the HPE GXP POST code
+	  capture block. This creates a /dev/postcode character
+	  device that returns host POST codes as they are written
