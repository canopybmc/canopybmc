/dts-v1/;

#include "aspeed-g6.dtsi"
#include "aspeed-g6-pinctrl.dtsi"
#include <dt-bindings/gpio/aspeed-gpio.h>
#include <dt-bindings/clock/ast2600-clock.h>

/ {
	model = "Asus Kommando IPMI Expansion Card";
	compatible = "asus,ast2600-kommando-ipmi-card", "aspeed,ast2600";

	aliases {
		serial4 = &uart5;
	};

	chosen {
		stdout-path = "serial4:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		led-fault {
			gpios = <&gpio1 ASPEED_GPIO(C, 5) GPIO_ACTIVE_HIGH>;
			label = "panic_amber";
			panic-indicator;
			default-state = "off";
		};

		led-heartbeat {
			gpios = <&gpio0 ASPEED_GPIO(A, 7) GPIO_ACTIVE_LOW>;
			label = "heartbeat_green";
			linux,default-trigger = "timer";
		};

	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x40000000>;
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		video_engine_memory: video {
			size = <0x04000000>;
			alignment = <0x01000000>;
			compatible = "shared-dma-pool";
			reusable;
		};
	};

	pcie_lpc: pcie-lpc@1e789800 {
		compatible = "aspeed,ast2600-pcie-lpc","aspeed,ast2600-lpc-v2", "simple-mfd", "syscon";
		// add "aspeed,ast2600-lpc-v2" so that the driver probe it 
		// make this compatible on OpenBMC linux fork
		reg = <0x1e789800 0x800>;

		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0x1e789800 0x800>;

		pcie_kcs3: pcie-kcs@2c {
			compatible = "aspeed,ast2600-kcs-bmc";
			reg = <0x2c 0x1>, <0x38 0x1>, <0x44 0x1>;
			interrupts = <GIC_SPI 176 IRQ_TYPE_LEVEL_HIGH>;
			aspeed,lpc-io-reg = <0x3a2>;

			status = "okay";
		};
	};

	pwm_tach: pwm-tach-controller@1e610000 {
		compatible = "aspeed,ast2600-pwm-tach";
		reg = <0x1e610000 0x100>;
		clocks = <&syscon ASPEED_CLK_AHB>;
		resets = <&syscon ASPEED_RESET_PWM>;
		#pwm-cells = <3>;
	};

	fan0: pwm-fan0 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 0 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan1: pwm-fan1 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 1 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan2: pwm-fan2 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 2 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan3: pwm-fan3 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 3 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan4: pwm-fan4 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 4 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan5: pwm-fan5 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 5 40000 0>;
        #cooling-cells = <2>;
        cooling-levels = <124 152 180 204 228 252>;
    };
    fan6: pwm-fan6 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 6 40000 0>;
        #cooling-cells = <2>;
		cooling-levels = <124 152 180 204 228 252>;
    };
    fan7: pwm-fan7 {
        compatible = "pwm-fan";
        pwms = <&pwm_tach 7 40000 0>;
        #cooling-cells = <2>;
		cooling-levels = <124 152 180 204 228 252>;
    };
};

&pwm_tach {
    status = "okay";

    pinctrl-names = "default";
    pinctrl-0 = <&pinctrl_pwm0_default  &pinctrl_pwm1_default
                 &pinctrl_pwm2_default  &pinctrl_pwm3_default
                 &pinctrl_pwm4_default  &pinctrl_pwm5_default
                 &pinctrl_pwm6_default  &pinctrl_pwm7_default
                 &pinctrl_tach0_default &pinctrl_tach1_default
                 &pinctrl_tach2_default &pinctrl_tach3_default
                 &pinctrl_tach4_default &pinctrl_tach5_default
                 &pinctrl_tach6_default &pinctrl_tach7_default>;

    fan-0 { tach-ch = /bits/ 8 <0x00>; };
    fan-1 { tach-ch = /bits/ 8 <0x01>; };
    fan-2 { tach-ch = /bits/ 8 <0x02>; };
    fan-3 { tach-ch = /bits/ 8 <0x03>; };
    fan-4 { tach-ch = /bits/ 8 <0x04>; };
    fan-5 { tach-ch = /bits/ 8 <0x05>; };
    fan-6 { tach-ch = /bits/ 8 <0x06>; };
    fan-7 { tach-ch = /bits/ 8 <0x07>; };
};

&mdio2 {
    status = "okay";
	pinctrl-names = "default";
    pinctrl-0 = <&pinctrl_mdio3_default>;

    ethphy2: ethernet-phy@0 {
        compatible = "ethernet-phy-ieee802.3-c22";
        reg = <0>;
    };
};

&mac2{
    status = "okay";
    phy-mode = "rgmii";
    phy-handle = <&ethphy2>;
    pinctrl-names = "default";
    pinctrl-0 = <&pinctrl_rgmii3_default>;
};



&fmc {
	status = "okay";

	flash@0 {
		status = "okay";
		m25p,fast-read;
		label = "bmc";
		spi-max-frequency = <50000000>;
#include "openbmc-flash-layout-64.dtsi"
	};
};

