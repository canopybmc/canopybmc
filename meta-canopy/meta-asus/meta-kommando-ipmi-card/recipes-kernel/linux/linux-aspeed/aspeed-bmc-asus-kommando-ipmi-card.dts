&gpio1 {
	gpio-line-names =
	/*18A0 0*/  "","","","","","","","",
	/*18B0 8*/  "","","","","","","","",
	/*18C0 16*/ "","","","","","BMC_MLED","","",
	/*18D0 24*/ "","","","","","","","",
	/*18E0 32*/ "","","","","","","","";
};

&vhub {
	status = "okay";
};

&video {
	status = "okay";
	memory-region = <&video_engine_memory>;
};

&lpc_snoop{
	status = "okay";
	snoop-ports = <0x80>;
};